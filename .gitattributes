# Normalize line endings
* text=auto eol=lf

# Shell scripts always LF
*.sh text eol=lf

# Windows batch always CRLF
*.cmd text eol=crlf
*.bat text eol=crlf

# Source files — explicit LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.env text eol=lf

# Binary — no diffing or conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff2 binary
*.woff binary
*.ttf binary
*.eot binary
*.zip binary
*.pdf binary

# Exclude dev files from git archive
.claudeignore export-ignore
.gitleaks.toml export-ignore
CLAUDE.md export-ignore
CONTRIBUTING.md export-ignore
.github export-ignore
